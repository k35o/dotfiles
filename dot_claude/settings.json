{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "feedbackSurveyRate": 0,
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "defaultToAgentsView": true,
  "leftArrowOpensAgents": true,
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(npx:*)",
      "Bash(npm exec:*)",
      "Bash(npm x:*)",
      "Bash(npm create:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpx:*)",
      "Bash(pnpm create:*)",
      "Bash(yarn dlx:*)",
      "Bash(yarn create:*)",
      "Bash(bunx:*)",
      "Bash(bun x:*)",
      "Bash(bun create:*)",
      "Bash(sudo:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "ask": [
      "Bash(git push:*)"
    ]
  },
  "sandbox": {
    "excludedCommands": [
      "git commit",
      "chezmoi",
      "pnpm install"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cmux-notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cmux-notify.sh"
          }
        ]
      }
    ]
  }
}
