{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "feedbackSurveyRate": 0,
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "defaultToAgentsView": true,
  "leftArrowOpensAgents": true,
  "autoMemoryEnabled": false,
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(npx:*)",
      "Bash(npm exec:*)",
      "Bash(npm x:*)",
      "Bash(npm create:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpx:*)",
      "Bash(pnpm create:*)",
      "Bash(yarn dlx:*)",
      "Bash(yarn create:*)",
      "Bash(bunx:*)",
      "Bash(bun x:*)",
      "Bash(bun create:*)",
      "Bash(sudo:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.development.local)",
      "Read(**/.env.production)",
      "Read(**/.env.production.local)",
      "Read(**/.env.test)",
      "Read(**/.env.test.local)",
      "Read(**/.env.staging)",
      "Read(**/.env.vault)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)"
    ]
  },
  "sandbox": {
    "excludedCommands": ["git commit", "chezmoi", "pnpm install"]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/security-hooks/run-hook.sh claude $HOME/.claude/security-hooks/prompt_submit.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/security-hooks/run-hook.sh claude $HOME/.claude/security-hooks/pattern_check.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/security-hooks/run-hook.sh claude $HOME/.claude/security-hooks/stop_review.py",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
